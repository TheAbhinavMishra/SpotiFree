{
  "version": 2,
  "rewrites": [
    {
      "source": "/ia-proxy/:path*",
      "destination": "https://archive.org/:path*"
    }
  ],
  "headers": [
    {
      "source": "/ia-proxy/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
